# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/real-estate-db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Cloudinary Configuration (property images/videos)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional folder names
CLOUDINARY_PROPERTY_FOLDER=real-estate/properties
CLOUDINARY_PROPERTY_THUMBNAIL_FOLDER=real-estate/properties/thumbnails

# API Prefix
API_PREFIX=/api/v1

# Google Sheets Integration
# IMPORTANT:
# 1) Create a Google Sheet manually and copy its ID into GOOGLE_SHEET_ID
# 2) Share that sheet with your service account email as Editor
# 3) Set GOOGLE_SERVICE_ACCOUNT_JSON as one-line JSON string
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_BUYER_TAB=buyers
GOOGLE_SHEET_SELLER_TAB=sellers
GOOGLE_SHEET_LINK_TAB=buyer_seller_links
