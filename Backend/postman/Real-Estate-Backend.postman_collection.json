    {
      "name": "Properties",
      "item": [
        {
          "name": "Create Property (Seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data._id) {",
                  "  pm.environment.set('propertyId', json.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"2BHK Apartment in Dwarka\",\n  \"description\": \"Near metro and market\",\n  \"propertyType\": \"apartment\",\n  \"listingType\": \"sell\",\n  \"price\": 5000000,\n  \"negotiable\": true,\n  \"address\": \"A-12, Sector 10\",\n  \"city\": \"Delhi\",\n  \"state\": \"Delhi\",\n  \"pincode\": \"110075\",\n  \"locality\": \"Dwarka\",\n  \"landmark\": \"Near Metro Gate 2\",\n  \"specifications\": {\n    \"residential\": {\n      \"bhk\": 2,\n      \"bathrooms\": 2,\n      \"balconies\": 2,\n      \"furnishing\": \"semi-furnished\"\n    }\n  },\n  \"amenities\": [\"Gym\", \"Lift\", \"Security\"],\n  \"images\": [\"https://example.com/image1.jpg\"],\n  \"ownerName\": \"Anita Verma\",\n  \"contactNumber\": \"8888888888\",\n  \"ownershipType\": \"freehold\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/properties",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties"
              ]
            }
          }
        },
        {
          "name": "List Properties (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/properties?city=Delhi&listingType=sell&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties"
              ],
              "query": [
                {
                  "key": "city",
                  "value": "Delhi"
                },
                {
                  "key": "listingType",
